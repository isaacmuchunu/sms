# Use the Vite dev-server proxy in development to avoid CORS issues.
# The proxy forwards /api requests to the backend at http://localhost:5000.
VITE_API_URL=/api/v1

# For direct backend access (e.g. production builds or when not using the proxy):
# VITE_API_URL=http://localhost:5000/api/v1

# Stripe publishable key for card payments in the parent portal
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Optional: idle timeout in milliseconds (default 15 minutes)
# VITE_SESSION_IDLE_TIMEOUT_MS=900000
