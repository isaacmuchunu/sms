PORT=5000
# NeonDB (PostgreSQL) connection string
DATABASE_URL=postgresql://user:pass@host/db
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_REFRESH_EXPIRE=7d
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=your_seed_admin_password_here
AUTH_RATE_LIMIT_MAX=20
RATE_LIMIT_MAX=500

# Email (SMTP) configuration
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your_email_user_here
EMAIL_PASS=your_email_password_here
EMAIL_FROM="School Management System" <noreply@example.com>
EMAIL_SECURE=false

# SMS configuration (Africa's Talking)
AFRICAS_TALKING_USERNAME=your_africas_talking_username
AFRICAS_TALKING_API_KEY=your_africas_talking_api_key
AFRICAS_TALKING_SENDER_ID=

# Set to 'true' to log messages instead of sending real email/SMS (useful for development)
SKIP_EMAIL_SEND=false
SKIP_SMS_SEND=false

# M-Pesa (Safaricom Daraja) configuration
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_PASSKEY=your_mpesa_passkey
MPESA_SHORTCODE=your_mpesa_shortcode
MPESA_CALLBACK_BASE_URL=https://your-ngrok-or-domain.com

# Stripe configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Session / idle timeout
SESSION_IDLE_TIMEOUT_MS=900000

FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173
NODE_ENV=development
